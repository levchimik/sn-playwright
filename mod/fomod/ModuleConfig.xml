<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://qconsulting.ca/fo3/ModConfig5.0.xsd">
    <moduleName>Playwright</moduleName>
    <installSteps order="Explicit">
        <installStep name="Playwright">
            <optionalFileGroups order="Explicit">
                <group name="Core (required)" type="SelectAll">
                    <plugins order="Explicit">
                        <plugin name="Playwright">
                            <description>The Playwright plugin (SNPlaywright.esp + SNPlaywright.dll), its SKSE ini, the SkyrimNet prompt overrides that drive its sleep/telepathy/scene behaviour, the PrismaUI control panel, and the compiled MCM + controller scripts. Required.</description>
                            <files>
                                <file source="SNPlaywright.esp" destination="SNPlaywright.esp" priority="0"/>
                                <folder source="SKSE" destination="SKSE" priority="0"/>
                                <folder source="PrismaUI" destination="PrismaUI" priority="0"/>
                                <file source="Scripts\PW_Controller.pex" destination="Scripts\PW_Controller.pex" priority="0"/>
                                <file source="Scripts\PW_MCM.pex" destination="Scripts\PW_MCM.pex" priority="0"/>
                            </files>
                            <typeDescriptor>
                                <type name="Required"/>
                            </typeDescriptor>
                        </plugin>
                    </plugins>
                </group>
                <group name="Extras" type="SelectAny">
                    <plugins order="Explicit">
                        <plugin name="Papyrus source scripts (for modders)">
                            <description>Install the .psc source for PW_Controller and PW_MCM under Scripts\Source. Players do not need this; it is only useful if you want to recompile or study the scripts.</description>
                            <files>
                                <folder source="Scripts\Source" destination="Scripts\Source" priority="0"/>
                            </files>
                            <typeDescriptor>
                                <type name="Optional"/>
                            </typeDescriptor>
                        </plugin>
                    </plugins>
                </group>
            </optionalFileGroups>
        </installStep>
    </installSteps>
</config>
